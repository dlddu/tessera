{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "lib": ["ES2022"],
    "types": ["node", "electron-vite/node"]
  },
  "include": [
    "src/main/**/*.ts",
    "src/preload/**/*.ts",
    "src/shared/**/*.ts",
    "electron.vite.config.ts",
    "vitest.config.ts",
    "playwright.config.ts",
    "eslint.config.mjs",
    "test/e2e/**/*.ts",
    "test/unit/workspace.test.ts",
    "test/unit/surface.test.ts",
    "test/unit/file-io.test.ts",
    "test/unit/update.test.ts",
    "test/unit/container.test.ts"
  ]
}
