{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.web.tsbuildinfo",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["vite/client"]
  },
  "include": [
    "src/renderer/**/*.ts",
    "src/renderer/**/*.tsx",
    "src/renderer/env.d.ts",
    "src/shared/**/*.ts",
    "test/unit/**/*.ts"
  ],
  "exclude": [
    "test/unit/workspace.test.ts",
    "test/unit/surface.test.ts",
    "test/unit/file-io.test.ts"
  ]
}
